# SunSide — Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an.
# Die .env wird nicht ins Git eingecheckt.

# ── Deploy ────────────────────────────────────────────────
# Hetzner-Server für deploy/deploy.sh
SSH_TARGET=root@your-server-ip
REMOTE_DIR=/var/www/sunside

# ── Zukünftige Erweiterungen ──────────────────────────────
# Eigener OSRM-Server (Standard: öffentliche OSRM-Instanz)
# OSRM_BASE_URL=http://router.project-osrm.org

# GTFS-Feed-URL für DB/Flixbus (wird gespeichert in data/)
# GTFS_DB_FEED_URL=https://download.gtfs.de/germany/free/latest.zip
# GTFS_FLIXBUS_FEED_URL=
